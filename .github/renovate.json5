  {
  // Re-enable Renovate in "slow lane + security-only automerge" mode
  "enabled": true,

  "extends": [
    "config:recommended",

    // Supply-chain hardening for GitHub Actions: pin to immutable digests/SHAs, and let Renovate update them.
    "helpers:pinGitHubActionDigests"
  ],
  "pre-commit": {
    "enabled": true
  },

  // ----------------------------
  // SLOW LANE (default behavior)
  // ----------------------------
  // PRs are created immediately, but auto-merge is gated by minimumReleaseAge
  // combined with internalChecksFilter="strict" so merging waits until
  // the release has been stable for the configured period.
  "minimumReleaseAge": "14 days",
  "minimumReleaseAgeBehaviour": "timestamp-required",
  "prCreation": "immediate",
  "internalChecksFilter": "strict",

  // Slow down overall throughput/noise
  "prHourlyLimit": 1,
  "prConcurrentLimit": 2,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "dependencyDashboard": true,
  "dependencyDashboardAutoclose": true,
  "separateMultipleMajor": true,
  "major": {
    "automerge": true,
    "minimumReleaseAge": "14 days"
  },
  "minor": {
    "automerge": true,
    "minimumReleaseAge": "14 days"
  },
  "patch": {
    "automerge": true,
    "minimumReleaseAge": "7 days"
  },
  "digest": {
    "automerge": true
  },
  "schedule": [
    "after 8pm every weekday",
    "before 10am every weekday",
    "every weekend"
  ],
  "timezone": "America/Chicago",
  "labels": ["renovate"],
  "packageRules": [
    {
      "matchCategories": ["docker"],
      "pinDigests": true
    },
    {
      // Security/vulnerability updates should be applied immediately
      "matchUpdateTypes": ["vulnerability"],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchPackageNames": ["aquasecurity/trivy-action"],
      "allowedVersions": ">=0.35.0"
    },
    {
      "matchPackageNames": ["aquasecurity/setup-trivy"],
      "dependencyDashboardApproval": true
    }
  ]
}
